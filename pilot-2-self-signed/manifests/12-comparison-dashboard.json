{
  "dashboard": {
    "uid": "mesh-compare",
    "title": "Mesh Comparison: Sidecar vs Ambient vs Plain",
    "tags": [
      "istio",
      "comparison",
      "pilot-2"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "10s",
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "text",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 3
        },
        "options": {
          "mode": "markdown",
          "content": "## Mesh Comparison: **Sidecar** vs **Ambient** vs **Pure-K8s** (bookinfo)\nEqual load on all three (`./load.sh on` / `loadtest.py`). Latency = gateway-view (Istio for all 3 -> fair end-to-end). Resource panels break down by container so the **istio-proxy / ztunnel / waypoint tax** is visible."
        }
      },
      {
        "id": 2,
        "type": "row",
        "title": "Latency & Throughput",
        "collapsed": false,
        "gridPos": {
          "x": 0,
          "y": 3,
          "w": 24,
          "h": 1
        },
        "panels": []
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Response time p99 (gateway -> productpage)",
        "description": "p99 of full productpage response, measured by the ingress gateway (Istio for all 3).",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "fillOpacity": 18,
              "gradientMode": "opacity",
              "showPoints": "never",
              "spanNulls": true
            },
            "decimals": 0
          },
          "overrides": []
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": [
              "lastNotNull",
              "mean",
              "max"
            ]
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.99, sum by(le,destination_service_namespace)(rate(istio_request_duration_milliseconds_bucket{source_workload=~\".*gateway.*\",destination_service_namespace=~\"bookinfo-.*\"}[$__rate_interval])))",
            "legendFormat": "{{destination_service_namespace}}"
          }
        ]
      },
